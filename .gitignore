# v12: generated corpora / trained candidates / eval output — tracked as
# real artifacts in the chuk-experiments server instead, not in git
# history. Scripts, pins, manifests, and README stay tracked. Glob
# covers every corpus generation (v0, v1, ...), not just the first.
v12/corpus/c8_corpus_v*.jsonl
v12/corpus/c8_corpus_v*.txt
v12/corpus/c8_code_corpus.jsonl
v12/training/candidates/
v12/training/candidates.jsonl
bench/reports/

# Model-training checkpoints (~330MB each, any candidate/phase name --
# model_full.pt was the only one on disk when this rule was first written,
# narrower than it should've been) -- tracked as real artifacts in
# chuk-experiments, not git history. Repo-wide: this is a tokenizer repo,
# a stray .pt/.safetensors/.ckpt anywhere in it is a generated probe
# artifact, never a real deliverable (v11's own tracked artifacts are
# .bin/.json, unaffected). Small result JSONs and the training log stay
# tracked.
*.pt
*.safetensors
*.ckpt
